{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-web-director.local/schemas/quality.schema.json",
  "title": "AI Web Director quality.yaml",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "quality"
  ],
  "properties": {
    "quality": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "approved",
        "responsive",
        "accessibility",
        "performance",
        "seo",
        "design",
        "content",
        "security",
        "qa",
        "budget"
      ],
      "properties": {
        "approved": {
          "type": "boolean"
        },
        "responsive": {
          "type": "object"
        },
        "accessibility": {
          "type": "object"
        },
        "performance": {
          "type": "object"
        },
        "seo": {
          "type": "object"
        },
        "design": {
          "type": "object",
          "required": [
            "phase_0_gate"
          ],
          "properties": {
            "phase_0_gate": {
              "type": "object",
              "required": [
                "design_system_required",
                "craft_rules_required",
                "candidate_strategy_count",
                "candidate_strategies",
                "required_score_categories",
                "min_visual_score_average",
                "min_visual_score_axis",
                "first_view_alignment_required",
                "no_copy_provenance_required",
                "responsive_first_fold_widths"
              ],
              "properties": {
                "design_system_required": { "type": "boolean" },
                "craft_rules_required": {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 4
                },
                "candidate_strategy_count": {
                  "type": "integer",
                  "minimum": 3
                },
                "candidate_strategies": {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 3,
                  "uniqueItems": true
                },
                "required_score_categories": {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 8,
                  "uniqueItems": true
                },
                "min_visual_score_average": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100
                },
                "min_visual_score_axis": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100
                },
                "first_view_alignment_required": { "type": "boolean" },
                "no_copy_provenance_required": { "type": "boolean" },
                "responsive_first_fold_widths": {
                  "type": "array",
                  "items": { "type": "integer", "minimum": 1 },
                  "minItems": 4,
                  "uniqueItems": true
                }
              }
            }
          }
        },
        "content": {
          "type": "object"
        },
        "security": {
          "type": "object"
        },
        "qa": {
          "type": "object"
        },
        "budget": {
          "type": "object",
          "required": [
            "cost_mode",
            "meter_model_cost",
            "max_model_cost_usd",
            "max_design_generations_total",
            "max_design_candidates",
            "max_regeneration_rounds",
            "max_qa_runtime_minutes",
            "qa_timeout_action",
            "max_qa_timeout_recovery_cycles",
            "require_user_approval_above_usd"
          ],
          "properties": {
            "cost_mode": {
              "type": "string",
              "enum": [
                "subscription_usage",
                "api_metered",
                "manual",
                "unknown"
              ]
            },
            "meter_model_cost": {
              "type": "boolean"
            },
            "max_model_cost_usd": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0
            },
            "max_design_generations_total": {
              "type": "integer",
              "minimum": 1
            },
            "max_design_candidates": {
              "type": "integer",
              "minimum": 1
            },
            "max_regeneration_rounds": {
              "type": "integer",
              "minimum": 0
            },
            "max_qa_runtime_minutes": {
              "type": "integer",
              "minimum": 1
            },
            "qa_timeout_action": {
              "type": "string",
              "enum": [
                "self_diagnose_fix_rerun",
                "block",
                "report_only"
              ]
            },
            "max_qa_timeout_recovery_cycles": {
              "type": "integer",
              "minimum": 0
            },
            "require_user_approval_above_usd": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0
            }
          }
        }
      }
    }
  }
}
