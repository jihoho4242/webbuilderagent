{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiweb.local/schemas/engine-run.schema.json",
  "title": "Engine Run",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "status",
    "mode",
    "agent",
    "capability",
    "approval_hash",
    "events_path",
    "checkpoint_path",
    "workspace_path",
    "opendesign_contract",
    "blocking_issues"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "run_id": { "type": "string", "pattern": "^engine-run-" },
    "status": {
      "enum": ["dry_run", "blocked", "running", "waiting_approval", "failed", "no_changes", "passed", "cancelled"]
    },
    "mode": { "enum": ["safe_patch", "agentic_local", "external_approval"] },
    "agent": { "enum": ["codex", "openmanus"] },
    "sandbox": { "type": ["string", "null"], "enum": ["docker", "podman", null] },
    "approved": { "type": "boolean" },
    "dry_run": { "type": "boolean" },
    "capability": { "$ref": "engine-run-approval.schema.json" },
    "approval_hash": { "type": "string", "minLength": 32 },
    "events_path": { "type": "string", "pattern": "^\\.ai-web/runs/.+/events\\.jsonl$" },
    "approval_path": { "type": "string", "pattern": "^\\.ai-web/runs/.+/approvals\\.jsonl$" },
    "checkpoint_path": { "type": "string", "pattern": "^\\.ai-web/runs/.+/checkpoint\\.json$" },
    "workspace_path": { "type": "string", "pattern": "^\\.ai-web/tmp/agentic/.+/workspace$" },
    "agent_result_path": { "type": ["string", "null"], "pattern": "^\\.ai-web/runs/.+/artifacts/agent-result\\.json$" },
    "verification_path": { "type": ["string", "null"], "pattern": "^\\.ai-web/runs/.+/qa/verification\\.json$" },
    "preview_path": { "type": ["string", "null"], "pattern": "^\\.ai-web/runs/.+/qa/preview\\.json$" },
    "screenshot_evidence_path": { "type": ["string", "null"], "pattern": "^\\.ai-web/runs/.+/qa/screenshots\\.json$" },
    "design_verdict_path": { "type": ["string", "null"], "pattern": "^\\.ai-web/runs/.+/qa/design-verdict\\.json$" },
    "design_fidelity_path": { "type": ["string", "null"], "pattern": "^\\.ai-web/runs/.+/qa/design-fidelity\\.json$" },
    "opendesign_contract_path": { "type": ["string", "null"], "pattern": "^\\.ai-web/runs/.+/artifacts/opendesign-contract\\.json$" },
    "opendesign_contract": { "type": "object" },
    "copy_back_policy": { "type": ["object", "null"] },
    "verification": { "type": ["object", "null"] },
    "preview": { "type": ["object", "null"] },
    "screenshot_evidence": { "type": ["object", "null"] },
    "design_verdict": { "type": ["object", "null"] },
    "design_fidelity": { "type": ["object", "null"] },
    "blocking_issues": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
