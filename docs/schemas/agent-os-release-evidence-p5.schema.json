{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiweb.local/schemas/agent-os-release-evidence-p5.schema.json",
  "title": "Agent OS P5 Release Evidence",
  "type": "object",
  "required": ["schema_version", "release_id", "release_ready", "constitution_hash", "policy_coverage", "tool_gateway_coverage", "hitl_v2", "replay", "redteam", "eval", "brain", "self_improvement", "script_executor_neutralization", "validation", "blocking_issues"],
  "properties": {
    "schema_version": { "const": 1 },
    "release_id": { "type": "string" },
    "release_ready": { "type": "boolean" },
    "constitution_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "policy_coverage": { "type": "object" },
    "tool_gateway_coverage": { "type": "object" },
    "hitl_v2": { "type": "object" },
    "replay": { "type": "object" },
    "redteam": { "type": "object" },
    "eval": { "type": "object" },
    "brain": { "type": "object" },
    "self_improvement": { "type": "object" },
    "script_executor_neutralization": { "type": "object" },
    "validation": { "type": "object" },
    "blocking_issues": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
