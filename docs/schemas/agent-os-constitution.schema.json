{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiweb.local/schemas/agent-os-constitution.schema.json",
  "title": "Agent OS Constitution",
  "type": "object",
  "required": ["constitution_version", "constitution_id", "immutable", "rules", "change_process"],
  "properties": {
    "constitution_version": { "type": "string", "minLength": 1 },
    "constitution_id": { "type": "string", "minLength": 1 },
    "immutable": { "const": true },
    "rules": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "severity", "description"],
        "properties": {
          "id": { "enum": ["NO_SELF_PERMISSION_ESCALATION", "NO_POLICY_KERNEL_BYPASS", "NO_HITL_DOWNGRADE", "NO_EVAL_THRESHOLD_DOWNGRADE", "NO_SECRET_READ"] },
          "severity": { "const": "critical" },
          "description": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "change_process": {
      "type": "object",
      "required": ["requires_signed_pr", "requires_security_owner", "requires_two_person_review_for_l4_l5"],
      "properties": {
        "requires_signed_pr": { "const": true },
        "requires_security_owner": { "const": true },
        "requires_two_person_review_for_l4_l5": { "const": true }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
