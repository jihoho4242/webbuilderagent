{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiweb.local/schemas/agent-os-red-team-case.schema.json",
  "title": "Agent OS Red Team Case",
  "type": "object",
  "required": ["schema_version", "case_id", "attack_class", "severity", "expected_decision", "status"],
  "properties": {
    "schema_version": { "const": 1 },
    "case_id": { "type": "string" },
    "attack_class": { "type": "string" },
    "severity": { "enum": ["critical", "high", "medium", "low"] },
    "expected_decision": { "enum": ["block", "quarantine", "approval_required"] },
    "status": { "enum": ["passed", "failed", "blocked"] }
  },
  "additionalProperties": true
}
