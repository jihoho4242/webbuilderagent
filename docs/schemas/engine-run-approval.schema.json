{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiweb.local/schemas/engine-run-approval.schema.json",
  "title": "Engine Run Capability Envelope",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "goal",
    "mode",
    "agent",
    "opendesign_contract",
    "writable_globs",
    "allowed_tools",
    "forbidden",
    "limits",
    "copy_back"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "run_id": {
      "type": "string",
      "pattern": "^engine-run-"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "safe_patch",
        "agentic_local",
        "external_approval"
      ]
    },
    "agent": {
      "enum": [
        "codex",
        "openmanus",
        "openhands",
        "langgraph",
        "openai_agents_sdk"
      ]
    },
    "sandbox": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "docker",
        "podman",
        null
      ]
    },
    "opendesign_contract": {
      "type": [
        "object",
        "null"
      ]
    },
    "writable_globs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "allowed_tools": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "forbidden": {
      "type": "array",
      "items": {
        "enum": [
          "env",
          "credentials",
          "external_network",
          "deploy",
          "provider_cli",
          "git_push",
          "host_root_write"
        ]
      },
      "minItems": 1
    },
    "limits": {
      "type": "object",
      "required": [
        "max_cycles",
        "timeout_sec",
        "max_output_bytes"
      ],
      "properties": {
        "max_cycles": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "timeout_sec": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600
        },
        "max_output_bytes": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 200000
        }
      }
    },
    "copy_back": {
      "type": "object",
      "required": [
        "requires_validation",
        "secret_scan",
        "risk_classifier"
      ],
      "properties": {
        "requires_validation": {
          "const": true
        },
        "secret_scan": {
          "const": true
        },
        "risk_classifier": {
          "const": true
        }
      }
    }
  },
  "additionalProperties": true
}
