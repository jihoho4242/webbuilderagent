{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiweb.local/schemas/engine-scheduler-supervisor.schema.json",
  "title": "Engine Scheduler Supervisor",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "supervisor_driver",
    "daemon_driver",
    "worker_pool_driver",
    "service_type",
    "action",
    "decision",
    "run_selector",
    "selected_run_id",
    "approved",
    "execute",
    "dry_run",
    "install_performed",
    "install_status",
    "supervisor_artifact_path",
    "daemon_artifact_path",
    "heartbeat_path",
    "worker_pool_path",
    "leases_path",
    "queue_ledger_path",
    "ledger_path",
    "daemon_command",
    "restart_policy",
    "health_checks",
    "service_unit_templates",
    "operator_runbook",
    "production_readiness",
    "limitations",
    "blocking_issues"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "status": { "enum": ["recorded", "blocked", "dry_run"] },
    "supervisor_driver": { "const": "aiweb.engine_scheduler.supervisor.v1" },
    "daemon_driver": { "const": "aiweb.engine_scheduler.daemon.v1" },
    "worker_pool_driver": { "const": "aiweb.engine_scheduler.worker_pool.v1" },
    "service_type": { "const": "project_local_scheduler_supervisor_contract" },
    "action": { "const": "supervisor" },
    "decision": { "enum": ["supervisor_plan_recorded", "blocked"] },
    "run_selector": { "type": "string" },
    "selected_run_id": { "type": ["string", "null"] },
    "approved": { "type": "boolean" },
    "execute": { "type": "boolean" },
    "dry_run": { "type": "boolean" },
    "install_performed": { "const": false },
    "install_status": { "const": "not_installed_by_aiweb" },
    "supervisor_artifact_path": { "const": ".ai-web/scheduler/supervisor.json" },
    "daemon_artifact_path": { "const": ".ai-web/scheduler/daemon.json" },
    "heartbeat_path": { "const": ".ai-web/scheduler/daemon-heartbeat.json" },
    "worker_pool_path": { "const": ".ai-web/scheduler/worker-pool.json" },
    "leases_path": { "const": ".ai-web/scheduler/leases.json" },
    "queue_ledger_path": { "const": ".ai-web/scheduler/queue-ledger.jsonl" },
    "ledger_path": { "const": ".ai-web/scheduler/ledger.jsonl" },
    "max_ticks": { "type": "integer", "minimum": 0, "maximum": 1000 },
    "interval_seconds": { "type": "number", "minimum": 0, "maximum": 60 },
    "workers": { "type": "integer", "minimum": 1, "maximum": 16 },
    "daemon_command": {
      "type": "object",
      "required": ["argv", "working_directory", "operator_must_set_working_directory_to_project_root", "approval_boundary"],
      "properties": {
        "argv": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "working_directory": { "const": "." },
        "operator_must_set_working_directory_to_project_root": { "const": true },
        "approval_boundary": { "type": "string" }
      },
      "additionalProperties": false
    },
    "restart_policy": {
      "type": "object",
      "required": ["mode", "restart", "heartbeat_timeout_seconds", "lease_timeout_seconds", "max_backoff_seconds", "duplicate_claim_guard"],
      "properties": {
        "mode": { "const": "external_supervisor_restart_on_failure" },
        "restart": { "const": "on_failure" },
        "heartbeat_timeout_seconds": { "const": 300 },
        "lease_timeout_seconds": { "const": 300 },
        "max_backoff_seconds": { "type": "integer", "minimum": 1 },
        "duplicate_claim_guard": { "type": "string" }
      },
      "additionalProperties": true
    },
    "health_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "path", "rule"],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" },
          "rule": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "service_unit_templates": {
      "type": "object",
      "required": ["systemd_user_service", "launchd_plist", "windows_task_command", "portable_foreground_command"],
      "properties": {
        "systemd_user_service": { "type": "array", "items": { "type": "string" } },
        "launchd_plist": { "type": "array", "items": { "type": "string" } },
        "windows_task_command": { "type": "string" },
        "portable_foreground_command": { "type": "string" }
      },
      "additionalProperties": false
    },
    "operator_runbook": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "production_readiness": {
      "type": "object",
      "required": ["supervisor_contract_recorded", "os_service_installed", "distributed_worker_cluster", "remote_queue", "node_body_executor"],
      "properties": {
        "supervisor_contract_recorded": { "const": true },
        "os_service_installed": { "const": false },
        "distributed_worker_cluster": { "const": false },
        "remote_queue": { "const": false },
        "node_body_executor": { "const": "engine_run_resume_bridge" }
      },
      "additionalProperties": false
    },
    "limitations": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "blocking_issues": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
