{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiweb.local/schemas/engine-run-event.schema.json",
  "title": "Engine Run Event",
  "type": "object",
  "required": ["schema_version", "seq", "run_id", "actor", "phase", "trace_span_id", "type", "message", "at", "data", "redaction_status", "previous_event_hash", "event_hash"],
  "properties": {
    "schema_version": { "const": 1 },
    "seq": { "type": "integer", "minimum": 1 },
    "run_id": { "type": "string", "pattern": "^engine-run-" },
    "actor": { "enum": ["aiweb.engine_run"] },
    "phase": { "type": "string", "minLength": 1 },
    "trace_span_id": { "type": "string", "pattern": "^span-" },
    "type": {
      "enum": [
        "run.created",
        "backend.job.queued",
        "backend.job.started",
        "backend.job.finished",
        "backend.job.failed",
        "goal.understood",
        "design.contract.loaded",
        "design.contract.missing",
        "design.contract.changed",
        "preflight.started",
        "preflight.finished",
        "project.indexed",
        "memory.index.recorded",
        "authz.enforcement.recorded",
        "worker.adapter.registry.recorded",
        "graph.scheduler.planned",
        "graph.scheduler.started",
        "graph.node.finished",
        "graph.scheduler.finished",
        "sandbox.preflight.started",
        "sandbox.preflight.finished",
        "plan.created",
        "step.started",
        "tool.requested",
        "policy.decision",
        "tool.started",
        "tool.finished",
        "tool.blocked",
        "tool.action.requested",
        "tool.action.blocked",
        "design.fidelity.checked",
        "artifact.created",
        "preview.started",
        "preview.ready",
        "preview.failed",
        "preview.stopped",
        "screenshot.capture.started",
        "screenshot.capture.finished",
        "screenshot.capture.failed",
        "browser.observation.recorded",
        "browser.action_recovery.recorded",
        "browser.action_loop.recorded",
        "design.review.started",
        "design.review.finished",
        "design.review.failed",
        "design.fixture.recorded",
        "eval.benchmark.recorded",
        "supply_chain.gate.recorded",
        "design.repair.planned",
        "design.repair.started",
        "design.repair.finished",
        "qa.failed",
        "repair.planned",
        "patch.generated",
        "approval.requested",
        "approval.granted",
        "checkpoint.saved",
        "run.resumed",
        "run.quarantined",
        "run.finished"
      ]
    },
    "message": { "type": "string", "minLength": 1 },
    "at": { "type": "string", "minLength": 1 },
    "data": { "type": "object" },
    "redaction_status": { "enum": ["redacted_at_source"] },
    "previous_event_hash": { "type": ["string", "null"], "pattern": "^sha256:[a-f0-9]{64}$" },
    "event_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  },
  "additionalProperties": false
}
