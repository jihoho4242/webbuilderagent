{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiweb.local/schemas/engine-run-human-review-pack.schema.json",
  "title": "Engine Run Human Review Pack",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "pack_id",
    "created_at",
    "fixture_id",
    "fixture_source",
    "output_paths",
    "review_protocol",
    "human_input_contract",
    "candidate_baseline_template",
    "anti_fabrication_policy",
    "next_steps",
    "guardrails",
    "blocking_issues"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "status": { "enum": ["ready", "dry_run", "blocked"] },
    "pack_id": { "type": "string", "pattern": "^human-review-pack-[a-f0-9]{16}$" },
    "created_at": { "type": "string", "minLength": 1 },
    "fixture_id": {
      "anyOf": [
        { "type": "string", "pattern": "^design-fixture-[a-f0-9]{16}$" },
        { "type": "null" }
      ]
    },
    "fixture_source": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "enum": ["found", "missing"] },
        "path": { "type": ["string", "null"] },
        "fixture_id": { "type": ["string", "null"] },
        "recorded_at": { "type": ["string", "null"] },
        "design_status": { "type": ["string", "null"] },
        "reason": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "output_paths": {
      "type": "object",
      "required": ["review_pack_path", "candidate_human_baselines_path", "import_target_path", "validation_path"],
      "properties": {
        "review_pack_path": { "type": "string" },
        "candidate_human_baselines_path": { "type": "string" },
        "import_target_path": { "const": ".ai-web/eval/human-baselines.json" },
        "validation_path": { "const": ".ai-web/eval/human-baseline-validation.json" }
      },
      "additionalProperties": false
    },
    "review_protocol": {
      "type": "object",
      "required": ["purpose", "minimum_reviewer_count", "score_range", "score_axes", "evidence_required", "reviewer_requirements"],
      "properties": {
        "purpose": { "type": "string" },
        "minimum_reviewer_count": { "type": "integer", "minimum": 1 },
        "score_range": {
          "type": "object",
          "required": ["minimum", "maximum"],
          "properties": {
            "minimum": { "const": 0 },
            "maximum": { "const": 100 }
          },
          "additionalProperties": false
        },
        "score_axes": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "evidence_required": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "reviewer_requirements": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "human_input_contract": {
      "type": "object",
      "required": [
        "prepopulated_human_scores",
        "agent_must_not_fill_scores",
        "required_human_fields",
        "candidate_schema",
        "candidate_template_status"
      ],
      "properties": {
        "prepopulated_human_scores": { "const": false },
        "agent_must_not_fill_scores": { "const": true },
        "required_human_fields": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "candidate_schema": { "const": "engine-run-human-baselines.schema.json" },
        "candidate_template_status": { "const": "not_importable_until_human_completed" }
      },
      "additionalProperties": true
    },
    "candidate_baseline_template": { "type": "object" },
    "anti_fabrication_policy": {
      "type": "object",
      "required": [
        "requires_human_reviewer_evidence",
        "agent_must_not_fill_scores",
        "agent_must_not_invent_reviewer_ids",
        "template_contains_placeholders_only",
        "import_requires_approved_flag",
        "validate_rejects_uncalibrated_or_secret_corpus"
      ],
      "properties": {
        "requires_human_reviewer_evidence": { "const": true },
        "agent_must_not_fill_scores": { "const": true },
        "agent_must_not_invent_reviewer_ids": { "const": true },
        "template_contains_placeholders_only": { "const": true },
        "import_requires_approved_flag": { "const": true },
        "validate_rejects_uncalibrated_or_secret_corpus": { "const": true }
      },
      "additionalProperties": false
    },
    "next_steps": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "guardrails": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "blocking_issues": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
