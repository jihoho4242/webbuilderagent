#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "aiweb"
require "time"

class WebbuilderLauncher
  KNOWN_COMMANDS = %w[
    help --help -h version --version
    start init status runtime-plan scaffold-status setup build preview interview run design-brief design-system design-prompt design select-design scaffold supabase-secret-qa ingest-design next-task
    agent-run verify-loop qa-checklist qa-report repair qa-playwright qa-screenshot qa-a11y qa-lighthouse visual-critique visual-polish advance rollback resolve-blocker snapshot
    workbench component-map visual-edit github-sync deploy-plan deploy design-systems skills craft intent
  ].freeze

  def initialize(argv, stdin: STDIN, stdout: STDOUT, stderr: STDERR, root: Dir.pwd)
    @argv = argv.dup
    @stdin = stdin
    @stdout = stdout
    @stderr = stderr
    @root = root
  end

  def run
    return print_help if help_requested?
    return Aiweb::CLI.new(@argv, @root).run if passthrough_command?

    options = direct_start_options
    if options[:idea].empty?
      options = interview_for_start(options)
    else
      print_start_plan(options) unless options[:json]
    end

    Aiweb::CLI.new(start_args(options), @root).run
  rescue Aiweb::UserError => e
    @stderr.puts "Error: #{e.message}"
    e.exit_code
  end

  private

  def help_requested?
    @argv.length == 1 && %w[help --help -h].include?(@argv.first)
  end

  def print_help
    @stdout.puts <<~HELP
      웹빌더 — AI Web Director zero-start launcher

      가장 쉬운 시작:
        웹빌더
        웹빌더 "성수동 감성 로컬 카페 웹사이트"
        웹빌더 --path ~/Desktop/my-site "성수동 감성 로컬 카페 웹사이트"

      이어서 작업:
        웹빌더 --path ~/Desktop/my-site status
        웹빌더 --path ~/Desktop/my-site advance
        웹빌더 --path ~/Desktop/my-site scaffold --profile D
        웹빌더 --path ~/Desktop/my-site scaffold --profile S --dry-run
        웹빌더 --path ~/Desktop/my-site supabase-secret-qa --dry-run
        웹빌더 --path ~/Desktop/my-site agent-run --task latest --agent codex --dry-run
        웹빌더 --path ~/Desktop/my-site agent-run --task latest --agent codex --approved
        웹빌더 --path ~/Desktop/my-site verify-loop --max-cycles 3 --dry-run
        웹빌더 --path ~/Desktop/my-site verify-loop --max-cycles 3 --approved
        웹빌더 --path ~/Desktop/my-site runtime-plan
        웹빌더 --path ~/Desktop/my-site setup --install --dry-run
        웹빌더 --path ~/Desktop/my-site setup --install --approved
        웹빌더 --path ~/Desktop/my-site build --dry-run
        웹빌더 --path ~/Desktop/my-site preview --dry-run
        웹빌더 --path ~/Desktop/my-site preview
        웹빌더 --path ~/Desktop/my-site preview --stop
        웹빌더 --path ~/Desktop/my-site qa-screenshot --url http://127.0.0.1:4321 --dry-run
        웹빌더 --path ~/Desktop/my-site qa-a11y --url http://127.0.0.1:4321 --dry-run
        웹빌더 --path ~/Desktop/my-site qa-lighthouse --url http://127.0.0.1:4321 --dry-run
        웹빌더 --path ~/Desktop/my-site visual-critique --screenshot ./evidence/home.png --metadata ./evidence/home.json --dry-run
        웹빌더 --path ~/Desktop/my-site repair --from-qa latest --dry-run
        웹빌더 --path ~/Desktop/my-site visual-polish --repair --from-critique latest --dry-run
        웹빌더 --path ~/Desktop/my-site workbench --dry-run
        웹빌더 --path ~/Desktop/my-site workbench --export
        웹빌더 --path ~/Desktop/my-site workbench --serve --dry-run
        웹빌더 --path ~/Desktop/my-site workbench --serve --approved
        웹빌더 --path ~/Desktop/my-site component-map --dry-run
        웹빌더 --path ~/Desktop/my-site visual-edit --target component.hero.copy --prompt "이 섹션 더 고급스럽게" --dry-run
        웹빌더 --path ~/Desktop/my-site github-sync
        웹빌더 --path ~/Desktop/my-site deploy-plan --target cloudflare-pages
        웹빌더 --path ~/Desktop/my-site deploy --target cloudflare-pages --dry-run
        웹빌더 --path ~/Desktop/my-site deploy --target vercel --dry-run

      웹빌더가 숙지한 시작 순서:
        Phase 0: 웹 유형 / 난이도 / 릴리즈 범위 결정
        Phase 0.25: 품질 계약 승인
        Phase 0.5: 스택 프로필 확정
        Phase 1~2.5: 제품 / 콘텐츠 / IA / 데이터 / 보안 정리
        Phase 3~4: 디자인 탐색과 DESIGN.md 시스템화
        Phase 5~11: repo / 컴포넌트 / Golden Flow / 구현 / QA / 배포

      기본 스택 프로필:
        D — Astro + MDX/Content Collections + Cloudflare Pages + Tailwind
        S — Next.js + Supabase SSR placeholder scaffold (local-only)

      Profile S는 로컬 scaffold/QA 전용이다. Supabase 프로젝트 생성, 네트워크, deploy, install, build, preview를 수행하지 않는다.
      Profile S의 안전 템플릿은 supabase/env.example.template이며 NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY placeholder만 포함한다.
      활성 no-.env guardrail 때문에 .env.example은 의도적으로 생성하지 않으며, supabase-secret-qa는 .env/.env.*를 읽지 않고 안전 경로만 점검해 .ai-web/qa/supabase-secret-qa.json에 기록한다.
      런타임 준비 확인은 runtime-plan 또는 scaffold-status로 패키지 설치/Node 실행 없이 읽기 전용으로 점검한다.
      setup --install --dry-run은 쓰기/프로세스 실행 없이 예정 pnpm install 명령과 setup 로그/메타데이터 경로만 보여준다.
      setup --install의 실제 패키지 설치는 --approved가 있을 때만 로컬에서 실행하고 .ai-web/runs/setup-<timestamp>/stdout.log, stderr.log, setup.json 증거를 기록한다.
      setup은 build, preview, QA, repair, deploy, provider CLI, .env/.env.* 읽기/출력을 수행하지 않는다.
      verify-loop는 build → preview → qa-playwright → qa-a11y → qa-lighthouse → qa-screenshot → visual-critique → repair/visual-polish → agent-run을 승인된 로컬 루프로 연결한다.
      verify-loop --dry-run은 파일 쓰기와 프로세스 실행 없이 계획만 보여주며, 실제 루프는 --approved가 필요하고 패키지 설치/배포/provider CLI/.env 접근은 수행하지 않는다.
      빌드와 로컬 프리뷰는 runtime-plan 준비 상태가 ready일 때만 웹빌더 build/preview 또는 aiweb build/preview로 실행한다.
      preview는 scaffold dev 명령을 로컬에서 띄우는 PR10 경로이며 설치, .env 접근, Playwright/axe/repair/deploy를 수행하지 않는다.
      preview --dry-run은 설치/쓰기/프로세스 실행 없이 예정 URL, 명령, 로그/메타데이터 경로만 확인한다.
      preview --stop은 기록된 프리뷰 PID만 안전하게 종료한다.
      qa-playwright는 PR11 브라우저 QA 경로다. 실행 중인 preview 또는 --url이 필요하며, 이미 설치된 로컬 Playwright만 사용한다.
      qa-screenshot은 PR21 safe local screenshot evidence(안전한 로컬 스크린샷 증거) 경로다. localhost/127.0.0.1 --url만 허용하고 모바일/태블릿/데스크톱 캡처와 metadata.json을 .ai-web/qa/screenshots에 기록한다.
      qa-a11y는 이미 설치된 로컬 axe 실행 파일로 접근성 QA를 수행한다.
      qa-lighthouse는 이미 설치된 로컬 Lighthouse 실행 파일로 성능/SEO QA를 수행한다.
      qa-playwright/qa-screenshot/qa-a11y/qa-lighthouse는 패키지 설치, .env 접근, preview 시작, 자동 repair, deploy를 수행하지 않는다.
      각 QA 명령의 --dry-run은 파일 쓰기/프로세스 실행 없이 예정 URL, 명령, 로그/메타데이터/QA 결과 경로만 확인한다.
      visual-critique는 명시적으로 전달한 로컬 screenshot/metadata 증거나 --from-screenshots latest 결과를 평가해 .ai-web/visual에 결정론적 critique artifact를 기록한다. 브라우저 실행, 캡처, 설치, 네트워크/AI 호출, repair, deploy, .env 접근은 수행하지 않는다.
      visual-critique --dry-run은 쓰기/브라우저/프로세스 실행 없이 예정 artifact 경로와 입력 검증 결과만 확인한다.
      repair는 실패/blocked QA 결과를 bounded repair_loop, pre-repair snapshot, fix task 기록으로 연결하되 source auto-patch, build/QA 실행, install/preview/deploy/external hosting은 수행하지 않는다.
      repair는 .env/.env.* QA 경로를 거부하고 --max-cycles로 같은 QA source 반복 repair loop를 제한한다.
      repair --dry-run은 쓰기/스냅샷 복사/프로세스 실행 없이 예정 repair record, snapshot, fix task 경로만 확인한다.
      visual-polish --repair는 failed/repair/redesign visual critique 결과를 bounded local visual polish loop, pre-polish snapshot, polish task 기록으로 연결한다.
      visual-polish는 source auto-patch나 source file edit, build/QA 실행, preview/browser/capture, install, deploy, external hosting, network/AI 호출, .env 접근을 수행하지 않는다.
      visual-polish는 .env/.env.* critique 경로를 거부하고 --max-cycles로 같은 critique source 반복 polish loop를 제한한다.
      visual-polish --dry-run은 쓰기/스냅샷 복사/프로세스 실행 없이 예정 polish record, snapshot, task 경로만 확인한다.
      workbench는 chat/control, plan/artifacts, design candidates, selected DESIGN.md, preview, file tree, QA results, visual critique, run timeline, verify-loop status 패널을 정적 로컬 UI artifact로 계획/내보내거나 localhost 서버로 제공한다.
      workbench control은 aiweb run/design/build/preview/QA/repair/visual-polish/verify-loop 같은 선언적 CLI 명령 descriptor이며 .ai-web/state.yaml을 직접 수정하지 않는다.
      workbench export는 control 실행, preview/browser/QA/daemon 실행, 설치, network/AI 호출 없이 .ai-web/workbench/index.html 및 workbench.json만 쓴다.
      workbench --serve --dry-run은 host/port와 .ai-web/workbench/index.html, workbench.json, .ai-web/runs/workbench-serve-* 증거 경로만 계획하고 파일 쓰기/프로세스 실행/state.yaml 변경을 수행하지 않는다.
      workbench --serve --approved는 127.0.0.1/localhost에만 바인딩하는 로컬 서버를 시작하고 .ai-web/runs/workbench-serve-*에 메타데이터를 기록한다.
      component-map은 scaffold/source의 안정적인 data-aiweb-id 영역을 .ai-web/component-map.json으로 매핑한다. --dry-run은 쓰기 없이 예정 경로와 차단 여부만 확인한다.
      visual-edit은 --target DATA_AIWEB_ID와 --prompt TEXT로 선택 영역 편집 handoff만 만든다. source auto-patch, build/QA/browser/preview 실행, deploy, network/AI 호출, .env 접근은 수행하지 않는다.
      visual-edit --dry-run은 .ai-web/tasks/visual-edit-*.md 및 .ai-web/visual/visual-edit-*.json 예정 경로만 보고하고 파일을 쓰지 않는다.
      github-sync는 GitHub 동기화 계획만 보여주는 로컬 전용 명령이며 git push, network, provider CLI, build/preview/install, .env/.env.* 접근을 수행하지 않는다.
      deploy-plan은 Cloudflare Pages 또는 Vercel 배포 체크리스트만 보여주는 로컬 전용 명령이며 provider CLI, network, build/preview/install, .env/.env.* 접근을 수행하지 않는다.
      deploy는 --target cloudflare-pages|vercel --dry-run만 허용하며 실제 배포 시도는 unsafe deploy blocked로 차단한다.
      --dry-run은 설치/쓰기/빌드/프로세스 실행을 수행하지 않는 사전 점검 경로로 사용한다.

      고급 명령은 기존 aiweb 명령과 동일하게 사용할 수 있다.
    HELP
    0
  end

  def passthrough_command?
    return false if @argv.empty?

    args = @argv.dup
    until args.empty?
      arg = args.shift
      case arg
      when "--json", "--dry-run"
        next
      when "--path"
        args.shift
      when /\A--path=/
        next
      else
        return KNOWN_COMMANDS.include?(arg)
      end
    end
    false
  end

  def direct_start_options
    options = {
      path: default_project_path,
      profile: nil,
      advance: true,
      idea: "",
      json: false,
      dry_run: false
    }
    idea_parts = []
    args = @argv.dup

    until args.empty?
      arg = args.shift
      case arg
      when "--path"
        options[:path] = require_value(args.shift, "--path")
      when /\A--path=(.+)\z/
        options[:path] = Regexp.last_match(1)
      when "--profile"
        options[:profile] = require_value(args.shift, "--profile").upcase
      when /\A--profile=(.+)\z/
        options[:profile] = Regexp.last_match(1).upcase
      when "--idea"
        idea_parts << require_value(args.shift, "--idea")
      when /\A--idea=(.+)\z/
        idea_parts << Regexp.last_match(1)
      when "--no-advance"
        options[:advance] = false
      when "--json"
        options[:json] = true
      when "--dry-run"
        options[:dry_run] = true
      else
        idea_parts << arg
      end
    end

    options[:idea] = idea_parts.join(" ").strip
    apply_recommended_profile!(options) unless options[:idea].empty?
    options
  end

  def require_value(value, option)
    raise Aiweb::UserError.new("#{option} requires a value", Aiweb::CLI::EXIT_VALIDATION_FAILED) if value.to_s.empty?

    value
  end

  def apply_recommended_profile!(options)
    return options unless options[:profile].to_s.empty?

    options[:profile] = Aiweb::IntentRouter.route(options[:idea]).fetch("recommended_profile")
    options
  end

  def interview_for_start(options)
    @stdout.puts "웹빌더를 시작합니다. 처음부터 필요한 순서대로 잡아갈게요."
    @stdout.puts

    options[:idea] = ask_required("만들고 싶은 웹을 한 문장으로 적어줘")
    apply_recommended_profile!(options)
    options[:path] = ask("프로젝트 폴더", options[:path])
    options[:profile] = ask("스택 프로필 A/B/C/D", options[:profile]).upcase
    advance_answer = ask("품질 계약 게이트까지 자동 진행", options[:advance] ? "Y" : "N")
    options[:advance] = !advance_answer.match?(/\A(n|no|아니|아니오)\z/i)

    print_start_plan(options)
    options
  end

  def ask(label, default)
    @stdout.print "#{label} [#{default}]: "
    line = @stdin.gets
    raise Aiweb::UserError.new("input ended before #{label}", Aiweb::CLI::EXIT_VALIDATION_FAILED) if line.nil?

    value = line.strip
    value.empty? ? default : value
  end

  def ask_required(label)
    3.times do
      @stdout.print "#{label}: "
      line = @stdin.gets
      raise Aiweb::UserError.new("input ended before #{label}", Aiweb::CLI::EXIT_VALIDATION_FAILED) if line.nil?

      value = line.strip
      return value unless value.empty?

      @stdout.puts "아이디어가 있어야 시작할 수 있어요."
    end
    raise Aiweb::UserError.new("website idea is required", Aiweb::CLI::EXIT_VALIDATION_FAILED)
  end

  def print_start_plan(options)
    @stdout.puts
    @stdout.puts "웹빌더 실행 순서"
    @stdout.puts "1. 프로젝트 폴더 생성: #{File.expand_path(options[:path])}"
    @stdout.puts "2. profile #{options[:profile]}로 Director 초기화"
    @stdout.puts "3. 아이디어 인터뷰 문서 생성"
    @stdout.puts(options[:advance] ? "4. phase-0.25 품질 계약 게이트까지 이동" : "4. phase-0에서 멈춤")
    @stdout.puts
  end

  def start_args(options)
    args = []
    args << "--json" if options[:json]
    args << "--dry-run" if options[:dry_run]
    args += ["start", "--path", options[:path]]
    args += ["--profile", options[:profile]] unless options[:profile].to_s.empty?
    args += ["--idea", options[:idea]]
    args << "--no-advance" unless options[:advance]
    args
  end

  def default_project_path
    File.expand_path("~/Desktop/웹빌더-#{Time.now.strftime("%Y%m%d-%H%M%S")}")
  end
end

exit WebbuilderLauncher.new(ARGV).run
