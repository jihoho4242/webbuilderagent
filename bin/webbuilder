#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "aiweb"
require "time"

class WebbuilderLauncher
  KNOWN_COMMANDS = %w[
    help --help -h version --version
    start init status runtime-plan scaffold-status build preview interview run design-brief design-system design-prompt design select-design scaffold ingest-design next-task
    qa-checklist qa-report repair qa-playwright qa-a11y qa-lighthouse advance rollback resolve-blocker snapshot
    design-systems skills craft intent
  ].freeze

  def initialize(argv, stdin: STDIN, stdout: STDOUT, stderr: STDERR, root: Dir.pwd)
    @argv = argv.dup
    @stdin = stdin
    @stdout = stdout
    @stderr = stderr
    @root = root
  end

  def run
    return print_help if help_requested?
    return Aiweb::CLI.new(@argv, @root).run if passthrough_command?

    options = direct_start_options
    if options[:idea].empty?
      options = interview_for_start(options)
    else
      print_start_plan(options) unless options[:json]
    end

    Aiweb::CLI.new(start_args(options), @root).run
  rescue Aiweb::UserError => e
    @stderr.puts "Error: #{e.message}"
    e.exit_code
  end

  private

  def help_requested?
    @argv.length == 1 && %w[help --help -h].include?(@argv.first)
  end

  def print_help
    @stdout.puts <<~HELP
      мЫєлєМлНФ вАФ AI Web Director zero-start launcher

      к∞АмЮ• мЙђмЪі мЛЬмЮС:
        мЫєлєМлНФ
        мЫєлєМлНФ "мД±мИШлПЩ к∞РмД± л°Ьмїђ мєінОШ мЫємВђмЭінКЄ"
        мЫєлєМлНФ --path ~/Desktop/my-site "мД±мИШлПЩ к∞РмД± л°Ьмїђ мєінОШ мЫємВђмЭінКЄ"

      мЭімЦімДЬ мЮСмЧЕ:
        мЫєлєМлНФ --path ~/Desktop/my-site status
        мЫєлєМлНФ --path ~/Desktop/my-site advance
        мЫєлєМлНФ --path ~/Desktop/my-site scaffold --profile D
        мЫєлєМлНФ --path ~/Desktop/my-site runtime-plan
        мЫєлєМлНФ --path ~/Desktop/my-site build --dry-run
        мЫєлєМлНФ --path ~/Desktop/my-site preview --dry-run
        мЫєлєМлНФ --path ~/Desktop/my-site preview
        мЫєлєМлНФ --path ~/Desktop/my-site preview --stop
        мЫєлєМлНФ --path ~/Desktop/my-site qa-a11y --url http://127.0.0.1:4321 --dry-run
        мЫєлєМлНФ --path ~/Desktop/my-site qa-lighthouse --url http://127.0.0.1:4321 --dry-run
        мЫєлєМлНФ --path ~/Desktop/my-site repair --from-qa latest --dry-run

      мЫєлєМлНФк∞А мИЩмІАнХЬ мЛЬмЮС мИЬмДЬ:
        Phase 0: мЫє мЬ†нШХ / лВЬмЭілПД / л¶іл¶ђм¶И л≤ФмЬД к≤∞м†Х
        Phase 0.25: нТИмІИ к≥ДмХљ мКємЭЄ
        Phase 0.5: мК§нГЭ нФДл°ЬнХД нЩХм†Х
        Phase 1~2.5: м†ЬнТИ / мљШнЕРмЄ† / IA / лН∞мЭінД∞ / л≥імХИ м†Хл¶ђ
        Phase 3~4: лФФмЮРмЭЄ нГРмГЙк≥Љ DESIGN.md мЛЬмК§нЕЬнЩФ
        Phase 5~11: repo / мїінПђлДМнКЄ / Golden Flow / кµђнШД / QA / л∞∞нПђ

      кЄ∞л≥Є мК§нГЭ нФДл°ЬнХД:
        D вАФ Astro + MDX/Content Collections + Cloudflare Pages + Tailwind

      лЯ∞нГАмЮД м§АлєД нЩХмЭЄмЭА runtime-plan лШРлКФ scaffold-statusл°Ь нМ®нВ§мІА мД§мєШ/Node мЛ§нЦЙ мЧЖмЭі мЭљкЄ∞ м†ДмЪ©мЬЉл°Ь м†Рк≤АнХЬлЛ§.
      лєМлУЬмЩА л°Ьмїђ нФДл¶ђлЈ∞лКФ runtime-plan м§АлєД мГБнГЬк∞А readyмЭЉ лХМлІМ мЫєлєМлНФ build/preview лШРлКФ aiweb build/previewл°Ь мЛ§нЦЙнХЬлЛ§.
      previewлКФ scaffold dev л™Ел†ємЭД л°ЬмїђмЧРмДЬ лЭДмЪ∞лКФ PR10 к≤љл°ЬмЭіл©∞ мД§мєШ, .env м†СкЈЉ, Playwright/axe/repair/deployл•Љ мИШнЦЙнХШмІА мХКлКФлЛ§.
      preview --dry-runмЭА мД§мєШ/мУ∞кЄ∞/нФДл°ЬмДЄмК§ мЛ§нЦЙ мЧЖмЭі мШИм†Х URL, л™Ел†є, л°ЬкЈЄ/л©ФнГАлН∞мЭінД∞ к≤љл°ЬлІМ нЩХмЭЄнХЬлЛ§.
      preview --stopмЭА кЄ∞л°ЭлРЬ нФДл¶ђлЈ∞ PIDлІМ мХИм†ДнХШк≤М мҐЕл£МнХЬлЛ§.
      qa-playwrightлКФ PR11 лЄМлЭЉмЪ∞м†А QA к≤љл°ЬлЛ§. мЛ§нЦЙ м§СмЭЄ preview лШРлКФ --urlмЭі нХДмЪФнХШл©∞, мЭілѓЄ мД§мєШлРЬ л°Ьмїђ PlaywrightлІМ мВђмЪ©нХЬлЛ§.
      qa-a11yлКФ мЭілѓЄ мД§мєШлРЬ л°Ьмїђ axe мЛ§нЦЙ нММмЭЉл°Ь м†СкЈЉмД± QAл•Љ мИШнЦЙнХЬлЛ§.
      qa-lighthouseлКФ мЭілѓЄ мД§мєШлРЬ л°Ьмїђ Lighthouse мЛ§нЦЙ нММмЭЉл°Ь мД±лК•/SEO QAл•Љ мИШнЦЙнХЬлЛ§.
      qa-playwright/qa-a11y/qa-lighthouseлКФ нМ®нВ§мІА мД§мєШ, .env м†СкЈЉ, preview мЛЬмЮС, мЮРлПЩ repair, deployл•Љ мИШнЦЙнХШмІА мХКлКФлЛ§.
      к∞Б QA л™Ел†ємЭШ --dry-runмЭА нММмЭЉ мУ∞кЄ∞/нФДл°ЬмДЄмК§ мЛ§нЦЙ мЧЖмЭі мШИм†Х URL, л™Ел†є, л°ЬкЈЄ/л©ФнГАлН∞мЭінД∞/QA к≤∞к≥Љ к≤љл°ЬлІМ нЩХмЭЄнХЬлЛ§.
      repairлКФ мЛ§нМ®/blocked QA к≤∞к≥Љл•Љ bounded repair_loop, pre-repair snapshot, fix task кЄ∞л°ЭмЬЉл°Ь мЧ∞к≤∞нХШлРШ source auto-patch, build/QA мЛ§нЦЙ, install/preview/deploy/external hostingмЭА мИШнЦЙнХШмІА мХКлКФлЛ§.
      repairлКФ .env/.env.* QA к≤љл°Ьл•Љ к±∞лґАнХШк≥† --max-cyclesл°Ь к∞ЩмЭА QA source л∞Шл≥µ repair loopл•Љ м†ЬнХЬнХЬлЛ§.
      repair --dry-runмЭА мУ∞кЄ∞/мК§лГЕмГЈ л≥µмВђ/нФДл°ЬмДЄмК§ мЛ§нЦЙ мЧЖмЭі мШИм†Х repair record, snapshot, fix task к≤љл°ЬлІМ нЩХмЭЄнХЬлЛ§.
      --dry-runмЭА мД§мєШ/мУ∞кЄ∞/лєМлУЬ/нФДл°ЬмДЄмК§ мЛ§нЦЙмЭД мИШнЦЙнХШмІА мХКлКФ мВђм†Д м†Рк≤А к≤љл°Ьл°Ь мВђмЪ©нХЬлЛ§.

      к≥†кЄЙ л™Ел†ємЭА кЄ∞м°і aiweb л™Ел†єк≥Љ лПЩмЭЉнХШк≤М мВђмЪ©нХ† мИШ мЮИлЛ§.
    HELP
    0
  end

  def passthrough_command?
    return false if @argv.empty?

    args = @argv.dup
    until args.empty?
      arg = args.shift
      case arg
      when "--json", "--dry-run"
        next
      when "--path"
        args.shift
      when /\A--path=/
        next
      else
        return KNOWN_COMMANDS.include?(arg)
      end
    end
    false
  end

  def direct_start_options
    options = {
      path: default_project_path,
      profile: nil,
      advance: true,
      idea: "",
      json: false,
      dry_run: false
    }
    idea_parts = []
    args = @argv.dup

    until args.empty?
      arg = args.shift
      case arg
      when "--path"
        options[:path] = require_value(args.shift, "--path")
      when /\A--path=(.+)\z/
        options[:path] = Regexp.last_match(1)
      when "--profile"
        options[:profile] = require_value(args.shift, "--profile").upcase
      when /\A--profile=(.+)\z/
        options[:profile] = Regexp.last_match(1).upcase
      when "--idea"
        idea_parts << require_value(args.shift, "--idea")
      when /\A--idea=(.+)\z/
        idea_parts << Regexp.last_match(1)
      when "--no-advance"
        options[:advance] = false
      when "--json"
        options[:json] = true
      when "--dry-run"
        options[:dry_run] = true
      else
        idea_parts << arg
      end
    end

    options[:idea] = idea_parts.join(" ").strip
    apply_recommended_profile!(options) unless options[:idea].empty?
    options
  end

  def require_value(value, option)
    raise Aiweb::UserError.new("#{option} requires a value", Aiweb::CLI::EXIT_VALIDATION_FAILED) if value.to_s.empty?

    value
  end

  def apply_recommended_profile!(options)
    return options unless options[:profile].to_s.empty?

    options[:profile] = Aiweb::IntentRouter.route(options[:idea]).fetch("recommended_profile")
    options
  end

  def interview_for_start(options)
    @stdout.puts "мЫєлєМлНФл•Љ мЛЬмЮСнХ©лЛИлЛ§. м≤ШмЭМлґАнД∞ нХДмЪФнХЬ мИЬмДЬлМАл°Ь мЮ°мХДк∞Ик≤МмЪФ."
    @stdout.puts

    options[:idea] = ask_required("лІМлУ§к≥† мЛґмЭА мЫємЭД нХЬ лђЄмЮ•мЬЉл°Ь м†БмЦім§Ш")
    apply_recommended_profile!(options)
    options[:path] = ask("нФДл°Ьм†ЭнКЄ нПілНФ", options[:path])
    options[:profile] = ask("мК§нГЭ нФДл°ЬнХД A/B/C/D", options[:profile]).upcase
    advance_answer = ask("нТИмІИ к≥ДмХљ к≤МмЭінКЄкєМмІА мЮРлПЩ мІДнЦЙ", options[:advance] ? "Y" : "N")
    options[:advance] = !advance_answer.match?(/\A(n|no|мХДлЛИ|мХДлЛИмШ§)\z/i)

    print_start_plan(options)
    options
  end

  def ask(label, default)
    @stdout.print "#{label} [#{default}]: "
    line = @stdin.gets
    raise Aiweb::UserError.new("input ended before #{label}", Aiweb::CLI::EXIT_VALIDATION_FAILED) if line.nil?

    value = line.strip
    value.empty? ? default : value
  end

  def ask_required(label)
    3.times do
      @stdout.print "#{label}: "
      line = @stdin.gets
      raise Aiweb::UserError.new("input ended before #{label}", Aiweb::CLI::EXIT_VALIDATION_FAILED) if line.nil?

      value = line.strip
      return value unless value.empty?

      @stdout.puts "мХДмЭілФФмЦік∞А мЮИмЦімХЉ мЛЬмЮСнХ† мИШ мЮИмЦімЪФ."
    end
    raise Aiweb::UserError.new("website idea is required", Aiweb::CLI::EXIT_VALIDATION_FAILED)
  end

  def print_start_plan(options)
    @stdout.puts
    @stdout.puts "мЫєлєМлНФ мЛ§нЦЙ мИЬмДЬ"
    @stdout.puts "1. нФДл°Ьм†ЭнКЄ нПілНФ мГЭмД±: #{File.expand_path(options[:path])}"
    @stdout.puts "2. profile #{options[:profile]}л°Ь Director міИкЄ∞нЩФ"
    @stdout.puts "3. мХДмЭілФФмЦі мЭЄнД∞лЈ∞ лђЄмДЬ мГЭмД±"
    @stdout.puts(options[:advance] ? "4. phase-0.25 нТИмІИ к≥ДмХљ к≤МмЭінКЄкєМмІА мЭілПЩ" : "4. phase-0мЧРмДЬ л©Имґ§")
    @stdout.puts
  end

  def start_args(options)
    args = []
    args << "--json" if options[:json]
    args << "--dry-run" if options[:dry_run]
    args += ["start", "--path", options[:path]]
    args += ["--profile", options[:profile]] unless options[:profile].to_s.empty?
    args += ["--idea", options[:idea]]
    args << "--no-advance" unless options[:advance]
    args
  end

  def default_project_path
    File.expand_path("~/Desktop/мЫєлєМлНФ-#{Time.now.strftime("%Y%m%d-%H%M%S")}")
  end
end

exit WebbuilderLauncher.new(ARGV).run
