#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require "json"
require "optparse"
require "rbconfig"
require "tmpdir"
require_relative "../lib/aiweb/runtime"

ROOT = File.expand_path("..", __dir__)
RUBY = RbConfig.ruby

class RuntimeMatrixCommandFailure < RuntimeError
  attr_reader :label, :exit_code, :status, :stdout, :stderr

  def initialize(label:, exit_code:, status:, stdout:, stderr:)
    @label = label
    @exit_code = exit_code
    @status = status
    @stdout = stdout.to_s
    @stderr = stderr.to_s
    super("#{label} failed with exit #{exit_code || status || "unknown"}")
  end
end

options = {
  matrix: ENV.fetch("AIWEB_ENGINE_RUN_RUNTIME_MATRIX", "docker,podman"),
  image: ENV.fetch("AIWEB_OPENMANUS_IMAGE", "aiweb-openmanus-smoke:ci"),
  base_image: ENV.fetch("AIWEB_RUNTIME_MATRIX_BASE_IMAGE", "python:3.12-alpine"),
  goal: "runtime matrix smoke patch",
  dry_run: false,
  json: false
}

OptionParser.new do |o|
  o.on("--matrix LIST", "Comma/space separated runtimes, default docker,podman") { |v| options[:matrix] = v }
  o.on("--image IMAGE", "Smoke OpenManus image tag") { |v| options[:image] = v }
  o.on("--base-image IMAGE", "Base image for generated smoke Dockerfile") { |v| options[:base_image] = v }
  o.on("--goal GOAL", "Engine-run goal") { |v| options[:goal] = v }
  o.on("--dry-run", "Print plan without building/running containers") { options[:dry_run] = true }
  o.on("--json", "Emit JSON") { options[:json] = true }
end.parse!

def runtimes(text)
  text.to_s.split(/[\s,]+/).map(&:strip).map(&:downcase).select { |runtime| %w[docker podman].include?(runtime) }.uniq
end

def executable(name)
  ENV.fetch("PATH", "").split(File::PATH_SEPARATOR).each do |dir|
    ["", ".cmd", ".exe", ".bat"].each do |ext|
      path = File.join(dir, "#{name}#{ext.strip}")
      return path if File.executable?(path) && File.file?(path)
    end
  end
  nil
end

def run!(label, env, *command, chdir:)
  result = Aiweb::Runtime::ProcessRunner.new.capture(
    Aiweb::Runtime::CommandSpec.new(
      argv: command,
      cwd: chdir,
      env: env,
      timeout: Integer(ENV.fetch("AIWEB_RUNTIME_MATRIX_COMMAND_TIMEOUT_SECONDS", "900")),
      max_output_bytes: 2_000_000,
      risk_class: "engine_runtime_matrix_verification",
      description: label,
      allow_shell_meta: true
    )
  )
  return [result.stdout, result.stderr] if result.success?

  raise RuntimeMatrixCommandFailure.new(
    label: label,
    exit_code: result.exit_code,
    status: result.status,
    stdout: result.stdout,
    stderr: result.stderr
  )
end

def current_user
  uid = Process.respond_to?(:uid) ? Process.uid : 1000
  gid = Process.respond_to?(:gid) ? Process.gid : uid
  uid = 1000 if uid.to_i <= 0
  gid = uid if gid.to_i <= 0
  "#{uid}:#{gid}"
end

def truncated(value, bytes = 120_000)
  text = value.to_s
  text.bytesize > bytes ? text.byteslice(0, bytes).to_s + "\n[truncated]" : text
end

def command_failure_payload(plan, error)
  payload = {
    "schema_version" => 1,
    "status" => "failed",
    "matrix" => plan.fetch("matrix", []),
    "image" => plan["image"],
    "base_image" => plan["base_image"],
    "sandbox_user" => plan["sandbox_user"],
    "dry_run" => false,
    "failed_step" => error.label,
    "exit_code" => error.exit_code,
    "process_status" => error.status,
    "stdout" => truncated(error.stdout),
    "stderr" => truncated(error.stderr)
  }
  parsed = JSON.parse(error.stdout.to_s)
  if parsed.is_a?(Hash)
    engine = parsed["engine_run"].is_a?(Hash) ? parsed["engine_run"] : {}
    payload["engine_run_summary"] = {
      "run_id" => engine["run_id"],
      "status" => engine["status"],
      "blocking_issues" => engine["blocking_issues"],
      "sandbox_preflight_path" => engine["sandbox_preflight_path"]
    }
    payload["runtime_matrix"] = engine.dig("sandbox_preflight", "runtime_matrix")
  end
  payload
rescue JSON::ParserError
  payload
end

def emit_runtime_matrix_result(options, result, exit_code)
  if options[:json]
    puts JSON.pretty_generate("engine_runtime_matrix_check" => result)
  else
    puts(result.map { |key, value| "#{key}: #{value}" }.join("\n"))
  end
  exit exit_code
end

matrix = runtimes(options.fetch(:matrix))
raise "runtime matrix is empty; expected docker, podman, or both" if matrix.empty?
sandbox_uid, sandbox_gid = current_user.split(":", 2).map(&:to_i)

plan = {
  "schema_version" => 1,
  "status" => "planned",
  "matrix" => matrix,
  "image" => options.fetch(:image),
  "base_image" => options.fetch(:base_image),
  "sandbox_user" => current_user,
  "dry_run" => options.fetch(:dry_run)
}

if options[:dry_run]
  puts(options[:json] ? JSON.pretty_generate("engine_runtime_matrix_check" => plan) : plan.map { |k, v| "#{k}: #{v}" }.join("\n"))
  exit 0
end

missing = matrix.reject { |runtime| executable(runtime) }
raise "missing required runtime executables: #{missing.join(", ")}" unless missing.empty?

begin
  Dir.mktmpdir("aiweb-runtime-matrix") do |tmp|
  context = File.join(tmp, "image")
  project = File.join(tmp, "project")
  FileUtils.mkdir_p(context)
  File.write(File.join(context, "openmanus-smoke.sh"), <<~SH)
    #!/bin/sh
    set -eu
    mkdir -p /workspace/_aiweb
    if [ -f /workspace/src/components/Hero.astro ]; then
      printf '\\n<!-- runtime matrix smoke patch -->\\n' >> /workspace/src/components/Hero.astro
    fi
    printf '{"schema_version":1,"status":"patched","sandbox_mode":"runtime-matrix-smoke"}\\n' > "${AIWEB_OPENMANUS_RESULT_PATH:-/workspace/_aiweb/engine-result.json}"
    echo "runtime matrix smoke openmanus"
  SH
  File.write(File.join(context, "Dockerfile"), <<~DOCKERFILE)
    FROM #{options.fetch(:base_image)}
    RUN addgroup -g #{sandbox_gid} aiweb || true
    RUN adduser -D -u #{sandbox_uid} aiweb || true
    COPY openmanus-smoke.sh /usr/local/bin/openmanus
    RUN chmod +x /usr/local/bin/openmanus
  DOCKERFILE

  matrix.each do |runtime|
    run!("#{runtime} build", ENV.to_h, runtime, "build", "-t", options.fetch(:image), context, chdir: ROOT)
  end

  run!("aiweb init", ENV.to_h, RUBY, File.join(ROOT, "bin", "aiweb"), "--path", project, "init", chdir: ROOT)
  FileUtils.mkdir_p(File.join(project, "src", "components"))
  File.write(File.join(project, "src", "components", "Hero.astro"), "<h1>Before</h1>\n")

  env = ENV.to_h.merge(
    "AIWEB_OPENMANUS_IMAGE" => options.fetch(:image),
    "AIWEB_ENGINE_RUN_RUNTIME_MATRIX" => matrix.join(","),
    "AIWEB_ENGINE_RUN_SANDBOX_USER" => current_user
  )
  run_id = "engine-run-runtime-matrix-smoke-#{Time.now.utc.strftime("%Y%m%dT%H%M%SZ")}"
  dry_stdout, = run!(
    "aiweb engine-run runtime matrix approval dry-run",
    env,
    RUBY,
    File.join(ROOT, "bin", "aiweb"),
    "--json",
    "--path",
    project,
    "engine-run",
    "--goal",
    options.fetch(:goal),
    "--agent",
    "openmanus",
    "--sandbox",
    matrix.first,
    "--run-id",
    run_id,
    "--dry-run",
    chdir: ROOT
  )
  dry_payload = JSON.parse(dry_stdout)
  dry_engine = dry_payload.fetch("engine_run")
  unless dry_engine.fetch("status") == "dry_run"
    raise "runtime matrix approval dry-run did not produce an executable plan\nSTDOUT:\n#{dry_stdout}"
  end
  approval_hash = dry_engine.fetch("approval_hash").to_s
  raise "runtime matrix approval dry-run did not produce approval_hash" if approval_hash.empty?

  stdout, stderr = run!(
    "aiweb engine-run runtime matrix",
    env,
    RUBY,
    File.join(ROOT, "bin", "aiweb"),
    "--json",
    "--path",
    project,
    "engine-run",
    "--goal",
    options.fetch(:goal),
    "--agent",
    "openmanus",
    "--sandbox",
    matrix.first,
    "--run-id",
    run_id,
    "--approval-hash",
    approval_hash,
    "--approved",
    chdir: ROOT
  )
  payload = JSON.parse(stdout)
  engine = payload.fetch("engine_run")
  preflight = engine.fetch("sandbox_preflight")
  matrix_evidence = preflight.fetch("runtime_matrix")
  unless engine.fetch("status") == "passed" && matrix_evidence.fetch("status") == "passed"
    raise "runtime matrix smoke failed\nSTDOUT:\n#{stdout}\nSTDERR:\n#{stderr}"
  end

  result = {
    "schema_version" => 1,
    "status" => "passed",
    "matrix" => matrix,
    "image" => options.fetch(:image),
    "sandbox_user" => current_user,
    "run_id" => engine.fetch("run_id"),
    "runtime_matrix" => matrix_evidence,
    "project" => project
  }
    emit_runtime_matrix_result(options, result, 0)
  end
rescue RuntimeMatrixCommandFailure => e
  emit_runtime_matrix_result(options, command_failure_payload(plan, e), 1)
rescue StandardError => e
  emit_runtime_matrix_result(
    options,
    plan.merge(
      "status" => "failed",
      "error_class" => e.class.name,
      "error" => truncated(e.message),
      "backtrace" => Array(e.backtrace).first(20)
    ),
    1
  )
end
